<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>📊 Rekap Survey Kondisi Kantor</title>
<style>
* { box-sizing:border-box; margin:0; padding:0; }
body { background:#f1f5f9; font-family:system-ui,-apple-system,sans-serif; min-height:100vh; }
.top-bar { background:#0f172a; color:#e2e8f0; padding:.7rem 1rem; display:flex; justify-content:space-between; align-items:center; font-size:.85rem; flex-wrap:wrap; gap:4px; }
.top-bar a { color:#93c5fd; text-decoration:none; }
.nav-link { padding:.25rem .5rem; border-radius:4px; }
.nav-link:hover { background:rgba(255,255,255,.1); color:#fff; }
.container { max-width:960px; margin:0 auto; padding:10px; }
h2 { font-size:1.05rem; color:#1e293b; }
.sub { font-size:.75rem; color:#64748b; margin:0 0 10px; }
.summary-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-bottom:10px; }
.dash-card { background:white; border-radius:10px; padding:10px 6px; text-align:center; box-shadow:0 1px 3px rgba(0,0,0,.06); }
.dash-card h3 { font-size:.65rem; color:#64748b; text-transform:uppercase; letter-spacing:.3px; }
.dash-card .num { font-size:1.3rem; font-weight:700; color:#0f172a; }
.dash-card .note { font-size:.6rem; color:#94a3b8; }
.tab-bar { display:flex; gap:4px; margin-bottom:10px; }
.tab-btn { flex:1; padding:7px; text-align:center; border-radius:8px; border:1.5px solid #e2e8f0; background:white; font-size:.78rem; cursor:pointer; color:#475569; }
.tab-btn.active { background:#7c3aed; color:white; border-color:#7c3aed; }
.item-table { width:100%; border-collapse:collapse; background:white; border-radius:8px; overflow:hidden; box-shadow:0 1px 3px rgba(0,0,0,.06); }
.item-table th { background:#f8fafc; padding:6px 5px; text-align:left; font-weight:600; font-size:.68rem; color:#475569; border-bottom:2px solid #e2e8f0; }
.item-table td { padding:5px; font-size:.7rem; border-bottom:1px solid #f1f5f9; color:#334155; }
.item-table th.sort { cursor:pointer; }
.item-table th.sort:hover { background:#eef2ff; }
.item-table th.asc::after, .item-table th.desc::after { font-size:.55rem; margin-left:2px; }
.item-table th.asc::after { content:"▲"; }
.item-table th.desc::after { content:"▼"; }
.legend { display:flex; gap:10px; margin:8px 0; font-size:.65rem; flex-wrap:wrap; }
.legend-dot { width:8px; height:8px; border-radius:2px; display:inline-block; }
.green { color:#16a34a; } .yellow { color:#ca8a04; } .orange { color:#ea580c; } .red { color:#dc2626; }
.empty { text-align:center; padding:20px; color:#94a3b8; font-size:.78rem; }
.thumb-landscape { width:100%;height:60px;object-fit:cover;border-radius:4px; }
.thumb-landscape[style*="height:"] { object-fit:cover; }
.foto-grid img { width:100%;height:70px;object-fit:cover;border-radius:4px; }
img.auto-orient { max-height:100px;object-fit:contain;background:#f1f5f9;border-radius:4px; }
</style>
</head>
<body>

<div class="top-bar">
  <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
    <strong>📋 Survey Kondisi Kantor</strong>
    {% for m in menu_items %}
    <a href="{{ m.url }}" class="nav-link">{{ m.icon }} {{ m.label }}</a>
    {% endfor %}
  </div>
  <div style="display:flex;align-items:center;gap:.8rem;flex-wrap:wrap;">
    <span style="font-size:.8rem;color:#93c5fd">👤 {{ user_name }}</span>
    <a href="/api/logout" class="nav-link" style="color:#fca5a5">Keluar</a>
  </div>
</div>

<div class="container">

<h2>📊 Rekap Survey Kondisi Kantor</h2>
<p class="sub">Ringkasan penilaian kelayakan outlet</p>

<div class="summary-grid">
  <div class="dash-card">
    <h3>Total Cabang</h3>
    <div class="num">{{ total_branches }}</div>
    <div class="note">dari master data</div>
  </div>
  <div class="dash-card" style="border-left:4px solid #16a34a;">
    <h3>✅ Diserahkan</h3>
    <div class="num">{{ done_submit|default(0) }}</div>
    <div class="note">{{ "%.0f"|format(done_submit/total_branches*100) if done_submit and total_branches>0 else 0 }}% dari total</div>
  </div>
  <div class="dash-card" style="border-left:4px solid #d97706;">
    <h3>📝 Draft</h3>
    <div class="num">{{ done_draft|default(0) }}</div>
    <div class="note">masih dikerjakan</div>
  </div>
  <div class="dash-card">
    <h3>Belum Pernah</h3>
    <div class="num">{{ total_branches - done_main }}</div>
    <div class="note">perlu segera diisi</div>
  </div>
  <div class="dash-card">
    <h3>Rata-rata Skor</h3>
    <div class="num">{{ avg_main }}%</div>
    <div class="note">{{ avg_dur }}</div>
  </div>
</div>

<!-- no separate best/worst strip — merged into Per Item tab -->

<div class="tab-bar">
  <div class="tab-btn active" data-tab="item">Per Item</div>
  <div class="tab-btn" data-tab="branch">Per Cabang</div>
  <div class="tab-btn" data-tab="foto">📸 Dokumentasi</div>
  <div class="tab-btn" data-tab="progress">📈 Progress</div>
  {% if user_id == '17012956' %}<div class="tab-btn" data-tab="session">Semua Session</div>{% endif %}
</div>

<!-- Tab: Per Item — Redesigned: analisa, perbaikan, prioritas -->
<div class="tab-panel" id="tab-item">
{% if problem_items %}
<script id="item-kantors-json" type="application/json">{{ item_kantors_json|safe }}</script>
{% set ns = namespace(merah=0, kuning=0, hijau=0) %}
{% for it in problem_items %}
  {% if it.avg_score < 60 %}{% set ns.merah = ns.merah + 1 %}
  {% elif it.avg_score < 80 %}{% set ns.kuning = ns.kuning + 1 %}
  {% else %}{% set ns.hijau = ns.hijau + 1 %}
  {% endif %}
{% endfor %}
{% set total_item = problem_items|length %}
{% set sum_score = namespace(val=0) %}
{% for it in problem_items %}{% set sum_score.val = sum_score.val + it.avg_score %}{% endfor %}
{% set rata_nasional = (sum_score.val / total_item)|round(1) if total_item > 0 else 0 %}

<!-- Section 1: Scorecard -->
<div class="summary-grid" style="margin-bottom:8px;">
  <div class="dash-card">
    <h3>🔴 Zona Merah</h3>
    <div class="num red">{{ ns.merah }}</div>
    <div class="note">&lt; 60%</div>
  </div>
  <div class="dash-card">
    <h3>🟡 Zona Kuning</h3>
    <div class="num yellow">{{ ns.kuning }}</div>
    <div class="note">60-80%</div>
  </div>
  <div class="dash-card">
    <h3>🟢 Zona Hijau</h3>
    <div class="num green">{{ ns.hijau }}</div>
    <div class="note">&gt; 80%</div>
  </div>
  <div class="dash-card">
    <h3>📊 Rata² Nasional</h3>
    <div class="num">{{ "%.1f"|format(rata_nasional) }}%</div>
    <div class="note">{{ total_item }} item dinilai</div>
  </div>
</div>

<!-- Section 2: Item Table -->
<table class="item-table">
<thead><tr>
  <th class="sort" onclick="sortT(this,0,'num')">#</th>
  <th class="sort" onclick="sortT(this,1,'str')">Kat</th>
  <th class="sort" onclick="sortT(this,2,'str')">Item</th>
  <th class="sort" onclick="sortT(this,3,'num')">Bobot</th>
  <th class="sort" onclick="sortT(this,4,'num')">Rata²</th>
  <th>Jawaban</th>
  <th style="width:38px;text-align:center" class="sort" onclick="sortT(this,6,'num')">⚡</th>
  <th style="width:55px;text-align:center">📸</th>
  <th style="width:50px;text-align:center">🏅</th>
  <th style="width:40px">🔍</th>
</tr></thead>
<tbody>

{% for it in problem_items %}
{% set badge = '' %}
{% for b in best_items %}{% if b.idx|string == it.idx|string %}{% set badge = '🏆' %}{% endif %}{% endfor %}
{% for w in worst_items %}{% if w.idx|string == it.idx|string %}{% set badge = '🔻' %}{% endif %}{% endfor %}
{% set pcls = 'red' if it.priority_label == 'tinggi' else 'yellow' if it.priority_label == 'sedang' else 'green' %}
{% set score_cls = 'red' if it.avg_score < 60 else 'yellow' if it.avg_score < 80 else 'green' %}
{% set prio_icon = '🔴' if it.priority_label == 'tinggi' else '🟡' if it.priority_label == 'sedang' else '🟢' %}
<tr>
  <td>{{ it.rank }}</td>
  <td>{{ it.cat }}</td>
  <td style="max-width:160px;white-space:normal;word-break:break-word;">{{ it.label }}</td>
  <td>{{ "%.0f"|format(it.weight * 100) }}%</td>
  <td class="{{ score_cls }}" style="font-weight:600;">{{ "%.1f"|format(it.avg_score) }}%</td>
  <td style="font-size:.6rem;">
    {% for o in it.opts %}<span style="color:{{ '#dc2626' if o.is_no else '#16a34a' }};margin-right:2px;">{{ o.label[:12] }}{{ '..' if o.label|length > 12 }} {{ o.count }}</span>{% if not loop.last %}<span style="margin:0 1px;color:#cbd5e1;">|</span>{% endif %}{% endfor %}
  </td>
  <td class="{{ pcls }}" style="font-weight:600;text-align:center;">{{ prio_icon }}</td>
  <td style="text-align:center;">{% if it.foto_issues > 0 %}<span style="color:#dc2626;font-weight:600;font-size:.7rem;">⚠️{{ it.foto_issues }}</span>{% else %}<span style="color:#94a3b8;font-size:.65rem;">—</span>{% endif %}</td>
  <td style="text-align:center;font-size:.8rem;">{{ badge }}</td>
  <td style="text-align:center;">
    <button onclick="toggelKantorList('{{ it.idx }}')" style="background:transparent;border:1px solid #d1d5db;border-radius:4px;padding:2px 6px;font-size:.7rem;cursor:pointer;color:#6366f1;">🔍</button>
  </td>
</tr>
<tr id="kantor-list-{{ it.idx }}" style="display:none;">
  <td colspan="10" style="padding:6px 10px;background:#f8fafc;border-bottom:2px solid #e2e8f0;">
<div style="font-size:.65rem;color:#64748b;margin-bottom:4px;">📋 Kantor dengan status kurang:</div>
    <div id="kantor-content-{{ it.idx }}" style="max-height:300px;overflow-y:auto;display:flex;flex-wrap:wrap;gap:6px;">
      <span style="color:#94a3b8;font-size:.6rem;">Memuat...</span>
    </div>
  </td>
</tr>
{% endfor %}
{% else %}
<tr><td colspan="9" class="empty">📭 Belum ada data survey. Silakan isi checklist terlebih dahulu.</td></tr>
{% endif %}
</tbody>
</table>
</div>

<!-- Tab: Per Cabang -->
<div class="tab-panel" id="tab-branch" style="display:none">
<style>
.filter-select {
  padding:4px 8px; border:1.5px solid #e2e8f0; border-radius:6px;
  font-size:.72rem; background:white; color:#334155;
}
</style>
<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;">
  <select id="filter-area" class="filter-select" onchange="filterBranchTable()">
    <option value="">Semua Area</option>
  </select>
  <select id="filter-wilayah" class="filter-select" onchange="filterBranchTable()" disabled>
    <option value="">Semua Wilayah</option>
  </select>
  <select id="filter-sort" class="filter-select" onchange="filterBranchTable()">
    <option value="kode">Urut: Kode</option>
    <option value="score-desc">Urut: Skor ↑</option>
    <option value="score-asc">Urut: Skor ↓</option>
  </select>
</div>
<div id="filter-count" style="font-size:.68rem;color:#64748b;margin-bottom:4px;"></div>
<table class="item-table" id="branch-table">
<thead><tr>
  <th class="sort" onclick="sortT(this,0,'str')">Kantor</th>
  <th class="sort" onclick="sortT(this,1,'str')">Nama</th>
  <th class="sort" onclick="sortT(this,2,'num')">Skor</th>
  <th class="sort" onclick="sortT(this,3,'str')">Status</th>
  <th>Aksi</th>
</tr></thead>
<tbody id="branch-tbody">
{% if merged_with_score %}
{% for m in merged_with_score %}
<tr data-area="{{ m.area_code }}" data-wilayah="{{ m.wilayah_code }}" data-score="{{ m.main }}">
  <td>{{ m.kode }}</td>
  <td>{{ m.label }}</td>
  <td class="{{ 'green' if m.main>=85 else 'yellow' if m.main>=65 else 'orange' if m.main>=45 else 'red' }}">{{ "%.1f"|format(m.main) }}%</td>
  <td>{{ m.main_workflow | default('-') }}</td>
  <td>
    <button onclick="downloadPdf('{{ m.kode }}')" style="background:#e0f2fe;color:#0369a1;border:1px solid #bae6fd;border-radius:6px;padding:3px 8px;font-size:.65rem;cursor:pointer;">📄 PDF</button>
  </td>
</tr>
{% endfor %}
{% else %}
<tr><td colspan="5" class="empty">📭 Belum ada data survey</td></tr>
{% endif %}
</tbody>
</table>
</div>

<!-- Tab: Dokumentasi (foto warnings) -->
<div class="tab-panel" id="tab-foto" style="display:none">
<div style="background:white;border-radius:10px;padding:10px;box-shadow:0 1px 3px rgba(0,0,0,.06);margin-bottom:8px;">
  <div style="font-size:.85rem;font-weight:600;color:#dc2626;margin-bottom:4px;">⚠️ Peringatan Dokumentasi</div>
  <div style="font-size:.7rem;color:#64748b;">Foto-foto yang terindikasi tidak sesuai dengan konteks pernyataan. Hasil analisa AI.</div>
</div>
<table class="item-table">
<thead><tr>
  <th class="sort" onclick="sortT(this,0,'str')">Kantor</th>
  <th class="sort" onclick="sortT(this,1,'str')">PIC</th>
  <th class="sort" onclick="sortT(this,2,'str')">Tgl</th>
  <th class="sort" onclick="sortT(this,3,'str')">Item</th>
  <th class="sort" onclick="sortT(this,4,'str')">Analisa AI</th>
  <th>PDF</th>
</tr></thead>
<tbody>
{% if foto_warnings %}
{% for fw in foto_warnings %}
<tr style="background:#fef2f2">
  <td>{{ fw.kode }}</td>
  <td>{{ fw.pic | default('-') }}</td>
  <td>{{ fw.tgl }}</td>
  <td><strong>{{ fw.cat }}</strong> — {{ fw.item }}</td>
  <td style="color:#dc2626;font-size:.65rem">{{ fw.desc[:80] }}{% if fw.desc|length > 80 %}...{% endif %}</td>
  <td><button onclick="downloadPdf('{{ fw.kode }}')" style="background:#e0f2fe;color:#0369a1;border:1px solid #bae6fd;border-radius:6px;padding:3px 8px;font-size:.65rem;cursor:pointer;">📄 PDF</button></td>
</tr>
{% endfor %}
{% else %}
<tr><td colspan="6" class="empty">✅ Semua dokumentasi sesuai — tidak ada peringatan</td></tr>
{% endif %}
</tbody>
</table>

{% if foto_referensi %}
<div style="background:white;border-radius:10px;padding:10px;box-shadow:0 1px 3px rgba(0,0,0,.06);margin:10px 0;">
  <div style="font-size:.85rem;font-weight:600;color:#0f172a;margin-bottom:4px;">📸 Contoh Dokumentasi Baik</div>
  <div style="font-size:.7rem;color:#64748b;margin-bottom:8px;">Foto referensi dari cabang lain dengan status ideal — jadikan panduan dokumentasi.</div>
  {% for ref_idx, status_map in foto_referensi.items() %}
    {% if ref_idx < db_items_ref|length %}
      {% set it_ref = db_items_ref[ref_idx] %}
      <div style="margin-bottom:10px;">
        <div style="font-size:.7rem;font-weight:600;color:#334155;">{{ it_ref.cat }} — {{ it_ref.label }}</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;">
          {% for st_v, fotos in status_map.items() %}
            {% for f in fotos %}
              <div style="width:130px;border:1px solid #e2e8f0;border-radius:6px;padding:4px;background:#f8fafc;">
                <img src="{{ f.foto }}" class="foto-grid" onerror="this.style.display='none'">
                <div style="font-size:.6rem;color:#64748b;margin-top:2px;">{{ f.kode }} — skor:{{ st_v }} {% if f.relevan %}✅{% else %}⚠️{% endif %}</div>
                {% if f.desc %}<div style="font-size:.55rem;color:#94a3b8;">{{ f.desc[:50] }}{% if f.desc|length > 50 %}...{% endif %}</div>{% endif %}
              </div>
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}
</div>

<!-- Tab: Progress -->
<div class="tab-panel" id="tab-progress" style="display:none">
<div style="background:white;border-radius:10px;padding:10px;box-shadow:0 1px 3px rgba(0,0,0,.06);margin-bottom:8px;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
    <div>
      <div style="font-size:.85rem;font-weight:600;color:#0f172a;">📈 Laporan Progress Survey</div>
      <div style="font-size:.7rem;color:#64748b;">Kondisi terakhir: <span id="report-ts">19-05-2026 16:43 WIB</span></div>
    </div>
    <button onclick="refreshReports()" style="background:#7c3aed;color:white;border:none;border-radius:6px;padding:6px 14px;font-size:.72rem;cursor:pointer;display:flex;align-items:center;gap:4px;">🔄 Refresh</button>
  </div>
  <div style="display:flex;flex-wrap:wrap;gap:8px;">
    <div style="flex:1;min-width:280px;">
      <div style="font-size:.7rem;font-weight:600;color:#16a34a;margin-bottom:4px;">✅ Diserahkan ({{ done_submit }} kantor)</div>
      <a href="/survey/reports/submitted_report.png" target="_blank"><img src="/survey/reports/submitted_report.png" style="width:100%;max-width:500px;border-radius:8px;border:1px solid #e2e8f0;cursor:pointer;" onclick="event.preventDefault();openLightbox(this.src)"></a>
      <div style="margin-top:4px;"><button onclick="shareImage('/survey/reports/submitted_report.png', '✅ Laporan Diserahkan')" style="background:#16a34a;color:white;border:none;border-radius:6px;padding:4px 10px;font-size:.65rem;cursor:pointer;">📤 Share</button></div>
    </div>
    <div style="flex:1;min-width:280px;">
      <div style="font-size:.7rem;font-weight:600;color:#ca8a04;margin-bottom:4px;">🟡 Draft / On Progress ({{ done_draft }} kantor)</div>
      <a href="/survey/reports/ongoing_report.png" target="_blank"><img src="/survey/reports/ongoing_report.png" style="width:100%;max-width:500px;border-radius:8px;border:1px solid #e2e8f0;cursor:pointer;" onclick="event.preventDefault();openLightbox(this.src)"></a>
      <div style="margin-top:4px;"><button onclick="shareImage('/survey/reports/ongoing_report.png', '🟡 Laporan Draft / On Progress')" style="background:#ca8a04;color:white;border:none;border-radius:6px;padding:4px 10px;font-size:.65rem;cursor:pointer;">📤 Share</button></div>
    </div>
    <div style="flex:1;min-width:280px;">
      <div style="font-size:.7rem;font-weight:600;color:#6b7280;margin-bottom:4px;">⬜ Belum Dibuat ({{ total_branches - done_submit - done_draft }} kantor)</div>
      <a href="/survey/reports/belum_dibuat_report.png" target="_blank"><img src="/survey/reports/belum_dibuat_report.png" style="width:100%;max-width:500px;border-radius:8px;border:1px solid #e2e8f0;cursor:pointer;" onclick="event.preventDefault();openLightbox(this.src)"></a>
      <div style="margin-top:4px;"><button onclick="shareImage('/survey/reports/belum_dibuat_report.png', '⬜ Laporan Belum Dibuat')" style="background:#6b7280;color:white;border:none;border-radius:6px;padding:4px 10px;font-size:.65rem;cursor:pointer;">📤 Share</button></div>
    </div>
  </div>
  <div style="margin-top:8px;font-size:.6rem;color:#94a3b8;">📌 Klik gambar untuk lihat besar. Laporan statis — refresh manual untuk update.</div>
</div>
</div>

<!-- Tab: Semua Session -->
{% if user_id == '17012956' %}
<div class="tab-panel" id="tab-session" style="display:none">
<table class="item-table">
<thead><tr>
  <th class="sort" onclick="sortT(this,0,'str')">Kantor</th>
  <th class="sort" onclick="sortT(this,1,'str')">PIC</th>
  <th class="sort" onclick="sortT(this,2,'str')">Tanggal</th>
  <th class="sort" onclick="sortT(this,3,'str')">Status</th>
  <th class="sort" onclick="sortT(this,4,'num')">Skor</th>
  <th>Aksi</th>
</tr></thead>
<tbody>
{% if all_sessions %}
{% for m in all_sessions %}
<tr>
  <td>{{ m.kode }}</td>
  <td>{{ m.pic | default('-') }}</td>
  <td>{{ m.tgl[:10] if m.tgl else '-' }}</td>
  <td>{{ m.workflow | default('-') }}</td>
  <td>{{ "%.1f"|format(m.score) }}%</td>
  <td>
    {% if user_id == '17012956' or user_role == 'admin' %}
    <button onclick="hapusSession('{{ m.kode }}')" style="background:#fee2e2;color:#dc2626;border:1px solid #fecaca;border-radius:6px;padding:3px 8px;font-size:.65rem;cursor:pointer;">🗑</button>
    {% endif %}
    <button onclick="downloadPdf('{{ m.kode }}')" style="background:#e0f2fe;color:#0369a1;border:1px solid #bae6fd;border-radius:6px;padding:3px 8px;font-size:.65rem;cursor:pointer;">📄 PDF</button>
  </td>
</tr>
{% endfor %}
{% else %}
<tr><td colspan="6" class="empty">📭 Belum ada session</td></tr>
{% endif %}
</tbody>
</table>
</div>
{% endif %}

<div class="legend">
  <span>Keterangan:</span>
  <span><span class="legend-dot" style="background:#16a34a"></span>&gt;85</span>
  <span><span class="legend-dot" style="background:#65a30d"></span>65-84</span>
  <span><span class="legend-dot" style="background:#ea580c"></span>45-64</span>
  <span><span class="legend-dot" style="background:#dc2626"></span>&lt;45</span>
</div>

<!-- Panel detil kantor -->
<div id="kantor-detail" style="display:none;margin-top:10px;">
  <div style="background:white;border-radius:10px;padding:12px;box-shadow:0 1px 3px rgba(0,0,0,.06);">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
      <div>
        <h3 id="detail-kode" style="font-size:.95rem;color:#0f172a;margin:0;"></h3>
        <div id="detail-pic" style="font-size:.7rem;color:#64748b;"></div>
      </div>
      <button id="btn-new-survey" onclick="startNewSurvey()" style="background:#7c3aed;color:white;border:none;border-radius:8px;padding:8px 14px;font-size:.75rem;cursor:pointer;font-weight:600;">+ Mulai Survei Baru</button>
    </div>

    <div id="detail-sesi" style="margin-bottom:8px;">
      <div style="font-size:.7rem;color:#64748b;margin-bottom:4px;">Riwayat Survei:</div>
      <div id="sesi-list" style="display:flex;flex-wrap:wrap;gap:4px;"></div>
    </div>

    <div id="detail-score" class="summary-grid" style="margin-bottom:8px;"></div>

    <div id="detail-compare">
      <div style="font-size:.7rem;color:#64748b;margin-bottom:4px;">Perbandingan 2 Survei Terakhir:</div>
      <div id="banding-items" style="max-height:400px;overflow-y:auto;"></div>
    </div>

    <div style="margin-top:8px;">
      <a href="#" onclick="closeKantor();return false;" style="font-size:.7rem;color:#64748b;">✕ Tutup</a>
    </div>
  </div>
</div>

</div><!-- /container -->

<script>
var currentKode = '';

function loadKantor(kode) {
  currentKode = kode;
  document.getElementById('kantor-detail').style.display = 'block';
  document.getElementById('detail-kode').textContent = '📂 ' + kode;
  document.getElementById('detail-pic').textContent = 'Memuat...';

  fetch('/survey/api/kantor-checklist/dashboard-data?kantor_code=' + encodeURIComponent(kode))
    .then(function(r){ return r.json(); })
    .then(function(d){
      if(!d.ok) { alert(d.error); return; }
      var sessions = d.sessions || [];
      document.getElementById('detail-pic').textContent = sessions.length + ' sesi survei';

      var sh = '';
      sessions.forEach(function(s, i){
        sh += '<a href="/survey/kantor-checklist/form/' + kode + '" style="background:#f1f5f9;padding:4px 8px;border-radius:6px;font-size:.7rem;color:#334155;text-decoration:none;border:1px solid #e2e8f0;display:inline-block;margin:2px;">';
        sh += s.nomor_survei || '#' + (i+1);
        if(i === sessions.length - 1) sh += ' ✅';
        sh += '</a>';
      });
      document.getElementById('sesi-list').innerHTML = sh || '<span style="color:#94a3b8;font-size:.7rem;">Belum ada survei</span>';

      var cats = d.cats || {};
      var catHtml = '';
      for(var ck in cats) {
        var c = cats[ck];
        catHtml += '<div class="dash-card"><h3>' + ck + ': ' + (c.name||'').substring(0,12) + '</h3><div class="num">' + c.score + '</div><div class="note">bobot ' + c.weight + '%</div></div>';
      }
      document.getElementById('detail-score').innerHTML = catHtml;

      var comps = d.comparisons || [];
      var items = d.items || [];
      var itemMap = {};
      items.forEach(function(it){ itemMap[it.idx] = it; });

      var icons = {'membaik':'🟢','memburuk':'🔴','stabil':'⚪','unknown':'⚫','new':'🆕'};
      var vlbl = {0:'✅',1:'⚠️',2:'❌'};

      if(comps.length > 0) {
        var bh = '<table style="width:100%;border-collapse:collapse;font-size:.7rem;"><thead><tr style="background:#f8fafc;"><th style="padding:4px;text-align:left;">#</th><th style="padding:4px;text-align:left;">Item</th><th style="padding:4px;text-align:center;">Trend</th><th style="padding:4px;text-align:center;">Sblm</th><th style="padding:4px;text-align:center;">Skrg</th></tr></thead><tbody>';
        comps.forEach(function(c){
          var it = itemMap[c.idx] || {};
          var icon = icons[c.trend] || '❓';
          var prv = c.prev_status !== null ? (vlbl[c.prev_status] || c.prev_status) : '-';
          var lat = c.latest_status !== null ? (vlbl[c.latest_status] || c.latest_status) : '-';
          bh += '<tr><td style="padding:4px;">' + c.idx + '</td><td style="padding:4px;">' + (it.label||'#').substring(0,40) + '</td><td style="padding:4px;text-align:center;">' + icon + '</td><td style="padding:4px;text-align:center;">' + prv + '</td><td style="padding:4px;text-align:center;">' + lat + '</td></tr>';
        });
        bh += '</tbody></table>';
        document.getElementById('banding-items').innerHTML = bh;
      } else {
        document.getElementById('banding-items').innerHTML = '<div style="color:#94a3b8;font-size:.7rem;padding:8px;">Butuh minimal 2 survei untuk perbandingan</div>';
      }
    })
    .catch(function(e){ alert('Gagal: ' + e); });
}

function closeKantor() {
  document.getElementById('kantor-detail').style.display = 'none';
  currentKode = '';
}

function startNewSurvey() {
  if(!currentKode) return;
  var btn = document.getElementById('btn-new-survey');
  btn.textContent = '⏳ Membuat...';
  btn.disabled = true;
  var f = new FormData();
  f.append('kantor_code', currentKode);
  fetch('/survey/api/kantor-checklist/new-survey', {method:'POST', body:f})
    .then(function(r){ return r.json(); })
    .then(function(d){
      if(d.ok && d.redirect) {
        window.location.href = d.redirect;
      } else {
        alert(d.error || 'Gagal');
        btn.textContent = '+ Mulai Survei Baru';
        btn.disabled = false;
      }
    })
    .catch(function(e){
      alert('Error: ' + e);
      btn.textContent = '+ Mulai Survei Baru';
      btn.disabled = false;
    });
}
</script>
<script>
// ── Branch Tree Filter: Area/Wilayah + Sorting ──
var branchTreeData = [];
var areaOptions = {};
var wilayahOptions = {};

function loadBranchTree() {
  fetch('/survey/api/kantor-checklist/branch-tree')
    .then(function(r){ return r.json(); })
    .then(function(d){
      if(!d.ok || !d.branches) return;
      branchTreeData = d.branches;
      // Build unique area + wilayah sets
      areaOptions = {};
      wilayahOptions = {};
      branchTreeData.forEach(function(b){
        if(!areaOptions[b.area_code]) areaOptions[b.area_code] = b.area_name;
        var wk = b.area_code + '|' + b.wilayah_code;
        if(!wilayahOptions[wk]) wilayahOptions[wk] = {wilayah_code: b.wilayah_code, wilayah_name: b.wilayah_name, area_code: b.area_code};
      });
      populateFilters();
    })
    .catch(function(e){ console.log('Branch tree load error:', e); });
}

function populateFilters() {
  var areaSel = document.getElementById('filter-area');
  var wilayahSel = document.getElementById('filter-wilayah');
  if(!areaSel) return;
  // Area dropdown
  var areaKeys = Object.keys(areaOptions).sort();
  areaKeys.forEach(function(ac){
    var opt = document.createElement('option');
    opt.value = ac;
    opt.textContent = areaOptions[ac] + ' (' + ac + ')';
    areaSel.appendChild(opt);
  });
  // Update wilayah based on current area
  updateWilayahOptions();
  // Initial filter count
  updateFilterCount();
}

function updateWilayahOptions() {
  var wilayahSel = document.getElementById('filter-wilayah');
  if(!wilayahSel) return;
  var selectedArea = document.getElementById('filter-area').value;
  wilayahSel.innerHTML = '<option value="">Semua Wilayah</option>';
  var items = [];
  for(var wk in wilayahOptions) {
    var w = wilayahOptions[wk];
    if(selectedArea && w.area_code !== selectedArea) continue;
    items.push(w);
  }
  items.sort(function(a,b){ return a.wilayah_code.localeCompare(b.wilayah_code); });
  items.forEach(function(w){
    var opt = document.createElement('option');
    opt.value = w.wilayah_code;
    opt.textContent = w.wilayah_name + ' (' + w.wilayah_code + ')';
    wilayahSel.appendChild(opt);
  });
  wilayahSel.disabled = items.length === 0 && !selectedArea;
}

function filterBranchTable() {
  var areaVal = document.getElementById('filter-area').value;
  var wilayahVal = document.getElementById('filter-wilayah').value;
  var sortVal = document.getElementById('filter-sort').value;
  var tbody = document.getElementById('branch-tbody');
  if(!tbody) return;
  var rows = tbody.querySelectorAll('tr');
  var visibleRows = [];
  rows.forEach(function(row){
    if(row.classList.contains('empty')) return;
    var rowArea = row.getAttribute('data-area') || '';
    var rowWil = row.getAttribute('data-wilayah') || '';
    var show = true;
    if(areaVal && rowArea !== areaVal) show = false;
    if(show && wilayahVal && rowWil !== wilayahVal) show = false;
    row.style.display = show ? '' : 'none';
    if(show) {
      row.style.background = (areaVal || wilayahVal) ? '#f0f9ff' : '';
      visibleRows.push(row);
    } else {
      row.style.background = '';
    }
  });
  // Sort visible rows
  if(sortVal === 'score-desc') {
    visibleRows.sort(function(a,b){
      var sa = parseFloat(a.getAttribute('data-score')) || -1;
      var sb = parseFloat(b.getAttribute('data-score')) || -1;
      return sb - sa;
    });
  } else if(sortVal === 'score-asc') {
    visibleRows.sort(function(a,b){
      var sa = parseFloat(a.getAttribute('data-score')) || -1;
      var sb = parseFloat(b.getAttribute('data-score')) || -1;
      return sa - sb;
    });
  } else {
    visibleRows.sort(function(a,b){
      return (a.getAttribute('data-area')||'').localeCompare(b.getAttribute('data-area')||'') ||
             (a.getAttribute('data-wilayah')||'').localeCompare(b.getAttribute('data-wilayah')||'') ||
             a.cells[0].textContent.localeCompare(b.cells[0].textContent);
    });
  }
  // Re-append sorted rows
  visibleRows.forEach(function(row){ tbody.appendChild(row); });
  updateFilterCount();
  if(areaVal !== document.getElementById('filter-area').value) updateWilayahOptions();
}

function updateFilterCount() {
  var el = document.getElementById('filter-count');
  if(!el) return;
  var tbody = document.getElementById('branch-tbody');
  if(!tbody) return;
  var total = 0, visible = 0;
  tbody.querySelectorAll('tr').forEach(function(row){
    if(row.classList.contains('empty')) return;
    total++;
    if(row.style.display !== 'none') visible++;
  });
  el.textContent = visible < total ? 'Menampilkan ' + visible + ' dari ' + total + ' cabang' : total + ' cabang';
}

// Load branch tree on page load
document.addEventListener('DOMContentLoaded', function(){ loadBranchTree(); });

function hapusSession(kode) {
  if(!confirm('Hapus semua session untuk kantor ' + kode + '?')) return;
  var f = new FormData();
  f.append('kantor_code', kode);
  fetch('/survey/api/kantor-checklist/delete-session', {method:'POST', body:f})
    .then(function(r){ return r.json(); })
    .then(function(d){
      if(d.ok) { alert('✅ Session ' + kode + ' dihapus'); location.reload(); }
      else { alert('❌ ' + (d.error||'Gagal')); }
    })
    .catch(function(e){ alert('Error: ' + e); });
}
// Toggle expandable kantor list per item
function downloadPdf(kode) {
  window.open('/survey/api/public/pdf/' + encodeURIComponent(kode) + '?dl=1', '_blank');
}

function toggelKantorList(itemIdx) {
  var row = document.getElementById('kantor-list-' + itemIdx);
  if(!row) return;
  var isVisible = row.style.display !== 'none';
  row.style.display = isVisible ? 'none' : 'table-row';
  if(!isVisible) {
    var content = document.getElementById('kantor-content-' + itemIdx);
    if(content && content.getAttribute('data-loaded') !== 'true') {
      try {
        var data = JSON.parse(document.getElementById('item-kantors-json').textContent || '{}');
        var kantors = data[itemIdx] || [];
        var html = '';
        if(kantors.length === 0) {
          html = '<div style="color:#16a34a;font-size:.65rem;width:100%;">\u2705 Semua layak untuk item ini</div>';
        } else {
          var scoreColors = ['#16a34a','#ca8a04','#ea580c','#dc2626','#6b7280'];
          var scoreBgs = ['#f0fdf4','#fefce8','#fff7ed','#fef2f2','#f9fafb'];
          var scoreBorders = ['#bbf7d0','#fde68a','#fed7aa','#fecaca','#e5e7eb'];
          kantors.forEach(function(k){
            var sv = k.status > 4 ? 4 : k.status;
            var bg = scoreBgs[sv] || '#f9fafb';
            var border = scoreBorders[sv] || '#e5e7eb';
            var statusColor = scoreColors[sv] || '#6b7280';
            var stLabel = (k.status_label || 'Status ' + k.status).substring(0,28);
            var fotoHtml = '';
            var aiHtml = '';
            if(k.foto) {
              fotoHtml = '<img src="' + k.foto + '" class="thumb-landscape" style="margin-top:3px;cursor:pointer;" onclick="openLightbox(&#39;' + k.foto + '&#39;)" onerror="this.style.display=\'none\'">';
            }
            if(k.foto_desc) {
              aiHtml = '<div style="color:#64748b;font-size:.55rem;margin-top:2px;">' + k.foto_desc.substring(0,80) + '</div>';
            }
            var fotoIssue = (k.foto && !k.foto_relevan) ? '<span style="color:#dc2626;font-size:.5rem;">\u26a0\ufe0f foto tidak sesuai</span>' : '';
            html += '<div style="background:' + bg + ';border:1px solid ' + border + ';border-radius:6px;padding:5px;font-size:.6rem;width:170px;vertical-align:top;">';
            html += '<div style="font-weight:600;color:#0f172a;">' + k.kantor_code + '</div>';
            html += '<div style="color:#64748b;">' + (k.nama_kantor || '').substring(0,28) + '</div>';
            html += '<div style="color:' + statusColor + ';font-weight:500;margin:2px 0;">' + stLabel + (k.status_is_no ? ' \u274c' : ' \u2705') + '</div>';
            html += fotoHtml;
            html += fotoIssue;
            html += aiHtml;
            html += '</div>';
          });
        }
        content.innerHTML = html;
        content.setAttribute('data-loaded', 'true');
      } catch(e) {
        content.innerHTML = '<div style="color:#dc2626;font-size:.65rem;">\u274c ' + e.message + '</div>';
      }
    }
  }
}

// Share via Web Share API — catat log dulu, baru share
function shareImage(url, title) {
  var btn = event.target;
  if(btn.disabled) return;
  if(!navigator.share) {
    btn.innerHTML = '❌ Browser gak support';
    setTimeout(function(){ btn.innerHTML = '📤 Share'; }, 2000);
    return;
  }
  btn.disabled = true;
  btn.innerHTML = '⏳...';
  // Catat log dulu
  var type = url.includes('submitted') ? 'submitted' : url.includes('ongoing') ? 'ongoing' : 'belum';
  fetch('/survey/api/log-share', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({type: type})
  }).catch(function(e){}).then(function(){
    return fetch(url + '?t=' + new Date().getTime()).then(function(r){ return r.blob(); });
  }).then(function(blob){
    var file = new File([blob], url.split('/').pop(), {type: 'image/png'});
    return navigator.share({
      title: title,
      text: title,
      files: [file]
    });
  }).then(function(){
    btn.innerHTML = '✅ Shared';
    setTimeout(function(){ btn.disabled = false; btn.innerHTML = '📤 Share'; }, 2000);
  }).catch(function(e){
    if(e.name !== 'AbortError') console.error(e);
    btn.innerHTML = '📤 Share';
    btn.disabled = false;
  });
}

// Refresh reports
function refreshReports() {
  var btn = event.target;
  if(btn.disabled) return;
  btn.disabled = true;
  btn.innerHTML = '⏳ Mendownload...';
  fetch('/survey/api/refresh-reports').then(function(r){ return r.json(); }).then(function(d){
    if(d.ok) {
      // Force browser to reload images by adding timestamp
      var ts = new Date().getTime();
      document.querySelectorAll('#tab-progress img').forEach(function(img){
        var src = img.getAttribute('src').split('?')[0];
        img.src = src + '?t=' + ts;
      });
      document.getElementById('report-ts').textContent = new Date().toLocaleString('id-ID', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) + ' WIB';
      btn.innerHTML = '✅ Berhasil!';
    } else {
      btn.innerHTML = '❌ Gagal';
    }
    setTimeout(function(){ btn.disabled = false; btn.innerHTML = '🔄 Refresh'; }, 2000);
  }).catch(function(e){
    btn.innerHTML = '❌ Error';
    setTimeout(function(){ btn.disabled = false; btn.innerHTML = '🔄 Refresh'; }, 2000);
  });
}

// Tab switching (minimal, server-reliable)
document.querySelectorAll('.tab-btn').forEach(function(b){
  b.addEventListener('click', function(){
    document.querySelectorAll('.tab-btn').forEach(function(x){ x.classList.remove('active'); });
    this.classList.add('active');
    document.querySelectorAll('.tab-panel').forEach(function(p){ p.style.display='none'; });
    var target = document.getElementById('tab-' + this.getAttribute('data-tab'));
    if(target) target.style.display='block';
    // Load branch tree & populate filters when branch tab first clicked
    if(this.getAttribute('data-tab') === 'branch' && branchTreeData.length === 0) {
      loadBranchTree();
    }
  });
});

// Sort function: pure vanilla, no framework
function sortT(header, colIdx, type) {
  var table = header.closest('table');
  var tbody = table.querySelector('tbody');
  var rows = Array.from(tbody.querySelectorAll('tr'));
  // Skip empty rows
  if(!rows.length || rows[0].querySelector('.empty')) return;
  var dir = header.classList.contains('asc') ? 'desc' : 'asc';
  table.querySelectorAll('th.sort').forEach(function(h){ h.classList.remove('asc','desc'); });
  header.classList.add(dir);
  rows.sort(function(a,b){
    var va = (a.cells[colIdx]||{}).textContent||'';
    var vb = (b.cells[colIdx]||{}).textContent||'';
    if(type==='num'){
      var na=parseFloat(va.replace(/[^0-9.]/g,''));
      var nb=parseFloat(vb.replace(/[^0-9.]/g,''));
      if(!isNaN(na)&&!isNaN(nb)) return dir==='asc'?na-nb:nb-na;
    }
    return dir==='asc'?va.localeCompare(vb):vb.localeCompare(va);
  });
  rows.forEach(function(r){ tbody.appendChild(r); });
}
</script>

<!-- Dashboard Lightbox -->
<div class="lightbox-overlay" id="lightbox-overlay" onclick="closeLightbox()">
  <div class="lightbox-close" onclick="closeLightbox()">✕</div>
  <img id="lightbox-img" src="" alt="Foto">
</div>

<style>
.lightbox-overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,.85); z-index:9999; justify-content:center; align-items:center; cursor:pointer; }
.lightbox-overlay.open { display:flex; }
.lightbox-overlay img { max-width:95vw; max-height:95vh; object-fit:contain; border-radius:8px; box-shadow:0 4px 20px rgba(0,0,0,.5); }
.lightbox-close { position:fixed; top:15px; right:20px; color:white; font-size:28px; cursor:pointer; background:rgba(0,0,0,.3); width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; z-index:10000; }
</style>
<script>
function openLightbox(src) {
  if(!src) return;
  document.getElementById('lightbox-img').src = src;
  document.getElementById('lightbox-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  document.getElementById('lightbox-overlay').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
  if(e.key === 'Escape') closeLightbox();
});
</script>
</body>
</html>
